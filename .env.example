# Node Environment
NODE_ENV=development

# OpenRouter API Key
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7

# GLPI Base URL (Example: https://glpi.example.com)
GLPI_BASE_URL=
GLPI_API_VERSION=v2.3

# GLPI V2 OAuth password grant auth.
GLPI_OAUTH_CLIENT_ID=
GLPI_OAUTH_CLIENT_SECRET=
GLPI_OAUTH_SCOPE=api

# OAuth Authorization Code flow (web login) - URL only
GLPI_OAUTH_AUTHORIZE_URL=
GLPI_OAUTH_TOKEN_URL=

# Keep empty to auto-build from NEXT_PUBLIC_APP_URL + /api/auth/glpi/callback
GLPI_OAUTH_REDIRECT_URI=
GLPI_USERNAME=
GLPI_PASSWORD=

# Public URL for web callbacks (Docker service hostname)
NEXT_PUBLIC_APP_URL=
