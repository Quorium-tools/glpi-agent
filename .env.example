OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Example: https://glpi.example.com
GLPI_BASE_URL=https://quori.fr36.glpi-network.cloud
GLPI_API_VERSION=v2.3

# GLPI V2 OAuth password grant auth.
GLPI_OAUTH_CLIENT_ID=
GLPI_OAUTH_CLIENT_SECRET=
GLPI_OAUTH_SCOPE=api
GLPI_USERNAME=
GLPI_PASSWORD=

# Use true to preview write operations without sending POST/PATCH/DELETE to GLPI.
GLPI_AGENT_DRY_RUN=false
