# Node Environment
NODE_ENV=development

# OpenRouter API Key
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7

# GLPI Base URL (Example: https://glpi.example.com)
GLPI_BASE_URL=
GLPI_API_VERSION=v2.3

# GLPI V2 OAuth password grant auth.
GLPI_OAUTH_CLIENT_ID=
GLPI_OAUTH_CLIENT_SECRET=
GLPI_OAUTH_SCOPE=api

# OAuth Authorization Code flow (web login)
GLPI_OAUTH_AUTHORIZE_PATH=/oauth/authorize.php
GLPI_OAUTH_TOKEN_PATH=/oauth/token.php

# Keep empty to auto-build from NEXT_PUBLIC_APP_URL + /api/auth/glpi/callback
GLPI_OAUTH_REDIRECT_URI=
GLPI_USERNAME=
GLPI_PASSWORD=

# Optional public app URL used to build callback URI, e.g. http://localhost:3005
NEXT_PUBLIC_APP_URL=http://glpi-web:3005

# Use true to preview write operations without sending POST/PATCH/DELETE to GLPI.
GLPI_AGENT_DRY_RUN=false
